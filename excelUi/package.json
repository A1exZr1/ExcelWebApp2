{
  "name": "excelui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run generate:api && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "generate:api": "nswag run",
    "type-check": "vue-tsc --build",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "ag-grid-vue3": "^34.3.1",
    "sass": "^1.100.0",
    "sass-loader": "^16.0.8",
    "vite-plugin-vuetify": "^2.1.3",
    "vue": "^3.5.35",
    "vuetify": "^3.12.7"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^22.19.19",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^8.0.4",
    "nswag": "^14.7.1",
    "prettier": "^3.8.3",
    "typescript": "~5.8.0",
    "vite": "^7.3.3",
    "vue-tsc": "^3.3.3"
  }
}
